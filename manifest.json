{
  "manifest_version": 3,
  "name": "Whatnot Profit & Cost Alerts (Analytics)",
  "version": "3.8.2",
  "description": "Full session analytics with Google Sheets sync: sale history, bid counts, chat log, auction timing, profit tracking with 15% fee on Whatnot.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://www.whatnot.com/*",
    "https://script.google.com/*",
    "https://script.googleusercontent.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.whatnot.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://www.whatnot.com/*"
      ],
      "js": [
        "bridge.js"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ]
}
